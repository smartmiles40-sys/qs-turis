# Copie este arquivo para .env e preencha com os dados do SEU projeto Supabase.
# (.env NÃO vai para o git.)  Painel: Supabase > Project Settings > API.

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave pública "anon" / publishable (NÃO use a service_role no front!)
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# SERVER-SIDE (sem prefixo VITE_ -> NÃO vai pro navegador). Usado pelas funções
# em /api (webhook de leads, gestão de usuários). Veja docs/INTEGRACOES.md.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LEAD_INBOUND_SECRET=

# ---------------------------------------------------------------------------
# WhatsApp (ChatApp): as variáveis CHATAPP_* ficam em .env.chatapp.local
# (server-side). Veja .env.chatapp.example e docs/WHATSAPP.md.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Webfone (Wavoip): token do dispositivo para chamadas de voz pelo WhatsApp.
# OPCIONAL — normalmente o token é configurado na tela Configurações → Webfone
# (salvo no banco). Se preenchido aqui, tem PRIORIDADE sobre o campo da tela.
# ---------------------------------------------------------------------------
VITE_WAVOIP_TOKEN=

# ---------------------------------------------------------------------------
# Sincronização QS -> Bitrix por WEBHOOK (na hora que o SDR age).
# Base dos webhooks do n8n, SEM barra final. O app acrescenta o path do evento
# (/qs-perdido, /qs-ganho, /qs-reuniao, /qs-nota).
# Ex.: https://SEU-N8N.hostinger.com/webhook
# Vazio = integração desligada (nada quebra; só não espelha no Bitrix).
# Importe o workflow n8n/qs-to-bitrix-webhook.workflow.json — veja n8n/README.md.
# ---------------------------------------------------------------------------
VITE_N8N_SYNC_BASE=
