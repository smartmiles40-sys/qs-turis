# Copie este arquivo para .env e preencha com os dados do SEU projeto Supabase.
# (.env NÃO vai para o git.)  Painel: Supabase > Project Settings > API.

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave pública "anon" / publishable (NÃO use a service_role no front!)
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# SERVER-SIDE (sem prefixo VITE_ -> NÃO vai pro navegador). Usado pelas funções
# em /api (webhook de leads, gestão de usuários). Veja docs/INTEGRACOES.md.
# ---------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LEAD_INBOUND_SECRET=

# ---------------------------------------------------------------------------
# WhatsApp (ChatApp): as variáveis CHATAPP_* ficam em .env.chatapp.local
# (server-side). Veja .env.chatapp.example e docs/WHATSAPP.md.
# ---------------------------------------------------------------------------
