# ChatApp (https://api.chatapp.online) — copie para .env.chatapp.local e preencha.
# .env.chatapp.local é LOCAL e não deve ir pro git. Na Vercel, cadastre estas
# mesmas variáveis em Project Settings > Environment Variables.

# Login do painel ChatApp (o mesmo que você usa pra entrar):
CHATAPP_EMAIL=
CHATAPP_PASSWORD=

# appId do seu app no ChatApp (ver painel / suporte):
CHATAPP_APP_ID=

# licenseId da licença (o número que aparece nas URLs da API):
CHATAPP_LICENSE_ID=

# Canal: grWhatsApp (WhatsApp via GreenAPI) | whatsApp | telegram | max ...
CHATAPP_MESSENGER=grWhatsApp

# Opcional: se setar, a rota /api/chatapp-send exige o header x-internal-secret
# com este valor (evita que estranhos disparem mensagens). Gere um valor aleatório.
INTERNAL_API_SECRET=

# Opcional: sobrescreve a base da API (default já é a correta):
# CHATAPP_BASE_URL=https://api.chatapp.online
